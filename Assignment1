#include <stdio.h>
#include <string.h>

#define BUFFER_CAPACITY 10

typedef struct {
    char data[BUFFER_CAPACITY];
    int writeIndex;      // position to write
    int readIndex;       // position to read
    int currentSize;     // number of stored elements
} CircularBuffer;

// Initialize buffer
void initializeBuffer(CircularBuffer *cb) {
    cb->writeIndex = 0;
    cb->readIndex = 0;
    cb->currentSize = 0;
}

// Check if buffer is full
int isBufferFull(CircularBuffer *cb) {
    return cb->currentSize == BUFFER_CAPACITY;
}

// Check if buffer is empty
int isBufferEmpty(CircularBuffer *cb) {
    return cb->currentSize == 0;
}

// Write data into buffer
void writeBuffer(CircularBuffer *cb, char value) {
    if (isBufferFull(cb)) {
        printf("Error: Buffer Overflow\n");
        return;
    }

    cb->data[cb->writeIndex] = value;
    cb->writeIndex = (cb->writeIndex + 1) % BUFFER_CAPACITY;
    cb->currentSize++;
}

// Read data from buffer
char readBuffer(CircularBuffer *cb) {
    if (isBufferEmpty(cb)) {
        printf("Error: Buffer Underflow\n");
        return '\0';
    }

    char value = cb->data[cb->readIndex];
    cb->readIndex = (cb->readIndex + 1) % BUFFER_CAPACITY;
    cb->currentSize--;

    return value;
}

int main() {
    CircularBuffer cb;
    initializeBuffer(&cb);

    char userName[50];

    printf("Enter your name: ");
    scanf("%49s", userName);

    // Required suffix (as stated in assignment)
    strcat(userName, "ESY-CE");

    // Write characters into buffer
    for (int i = 0; i < strlen(userName); i++) {
        writeBuffer(&cb, userName[i]);
    }

    // Read and print output
    printf("Output: ");
    while (!isBufferEmpty(&cb)) {
        printf("%c", readBuffer(&cb));
    }

    printf("\nBuffer is now empty.\n");

    return 0;
}
